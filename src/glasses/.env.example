# session-cockpit glasses — build-time config (Vite). Copy to .env.local (gitignored).
#
# Voice answers (Phase 4b): the STT backend for speaking an AskUserQuestion answer.
# Default provider is Deepgram (streaming, live interim transcript, ~$0.0065/min).
# With no key set, the voice affordance is hidden and the question screen falls back
# to tap-to-pick (which always works).
#
# You can also set these on-device via the QR/app URL (they persist to localStorage):
#   ?stt=<provider>&sttKey=<key>   e.g. ?stt=deepgram&sttKey=dg_xxx
# localStorage overrides env: cockpit.sttProvider / cockpit.sttKey.

# Provider: deepgram | soniox | whisper-api  (cloud built-ins need a key)
VITE_STT_PROVIDER=deepgram
# API key for the chosen provider.
VITE_STT_API_KEY=
# BCP-47 language hint.
VITE_STT_LANGUAGE=en
