{
  "name": "@nexus/glasses",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cockpit client for the session-cockpit hub — web dashboard now, Even G2 HUD (even-toolkit) next.",
  "scripts": {
    "dev": "vite --port 5273 --host",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 5273 --host",
    "qr": "./scripts/qr.sh",
    "build:pack": "tsc --noEmit && VITE_BASE=./ vite build --outDir dist-pack --emptyOutDir",
    "pack": "npm run build:pack && evenhub pack app.json ./dist-pack -o session-cockpit.ehpk",
    "sim": "./scripts/sim.sh"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.12",
    "even-toolkit": "^1.7.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^8.2.0",
    "upng-js": "^2.1.0"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.13",
    "@evenrealities/evenhub-simulator": "^0.8.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "~5.9.3",
    "vite": "^8.1.5"
  },
  "comment": "Phase 3b adds even-toolkit + @evenrealities/even_hub_sdk for the HUD; kept out of the first install so the dashboard installs clean."
}
